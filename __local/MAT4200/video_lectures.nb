Cell["\<\
Divergence theorem tells us that the (scalar) triple integral of div(F) dV is \
equal to the (vector) double integral of F dS over the boundary of the 3D \
region.\
\>", "Text",
 CellChangeTimes->{{3.980430215463166*^9, 
  3.980430246575203*^9}},ExpressionUUID->"787100f7-bc51-4887-bccd-\
77122c604b21"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"top", "[", 
   RowBox[{"r_", ",", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"core", "[", 
    RowBox[{"9", "\[Pi]"}], "]"}], "+", 
   RowBox[{"r", " ", 
    RowBox[{"Cos", "[", "\[Phi]", "]"}], "*", 
    RowBox[{"accelDirection", "[", 
     RowBox[{"9", "\[Pi]"}], "]"}]}], "+", 
   RowBox[{"r", " ", 
    RowBox[{"Sin", "[", "\[Phi]", "]"}], "*", 
    RowBox[{"binormalDirection", "[", 
     RowBox[{"9", "\[Pi]"}], "]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bottom", "[", 
   RowBox[{"r_", ",", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"core", "[", "0", "]"}], "+", 
   RowBox[{"r", " ", 
    RowBox[{"Cos", "[", "\[Phi]", "]"}], "*", 
    RowBox[{"accelDirection", "[", "0", "]"}]}], "+", 
   RowBox[{"r", " ", 
    RowBox[{"Sin", "[", "\[Phi]", "]"}], "*", 
    RowBox[{"binormalDirection", "[", "0", "]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ParametricPlot3D", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"surf", "[", 
      RowBox[{"\[Theta]", ",", "\[Phi]"}], "]"}], ",", "\[IndentingNewLine]", 
     
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", 
       RowBox[{"0", "\[Pi]"}], ",", 
       RowBox[{"9", "\[Pi]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Phi]", ",", "0", ",", 
       RowBox[{"2", "\[Pi]"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"SphericalRegion", "->", "True"}], ",", 
     RowBox[{"ImageSize", "->", "Large"}], ",", 
     RowBox[{"PerformanceGoal", "->", "\"\<Quality\>\""}]}], 
    "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"ParametricPlot3D", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"top", "[", 
      RowBox[{"r", ",", "\[Phi]"}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "1.6"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Phi]", ",", "0", ",", 
       RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", "Green"}]}], "\[IndentingNewLine]", "]"}], ",",
    "\[IndentingNewLine]", 
   RowBox[{"ParametricPlot3D", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"bottom", "[", 
      RowBox[{"r", ",", "\[Phi]"}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "1.6"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Phi]", ",", "0", ",", 
       RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", "Blue"}]}], "\[IndentingNewLine]", "]"}], ",",
    "\[IndentingNewLine]", 
   RowBox[{"Graphics3D", "[", 
    RowBox[{"{", 
     RowBox[{"Red", ",", 
      RowBox[{"PointSize", "[", "0.02", "]"}], ",", 
