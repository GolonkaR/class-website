      RowBox[{"Arrow", "[", " ", 
       RowBox[{"Tube", "[", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"top", "[", 
           RowBox[{"1", ",", "0"}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"top", "[", 
            RowBox[{"1", ",", "0"}], "]"}], "+", 
           RowBox[{"{", 
            RowBox[{"0", ",", 
