Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ParametricPlot3D", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", "\[Theta]", "]"}], ",", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}], ",", 
        RowBox[{"\[Theta]", "/", "10"}]}], "}"}], "+", 
      RowBox[{"r", " ", 
       RowBox[{"Cos", "[", "\[Phi]", "]"}], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
         RowBox[{"-", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", "0"}], "}"}]}], "+", 
      RowBox[{"r", " ", 
       RowBox[{"Sin", "[", "\[Phi]", "]"}], 
       RowBox[{"{", 
        RowBox[{
         FractionBox[
          RowBox[{"Sin", "[", "\[Theta]", "]"}], 
          SqrtBox["101"]], ",", 
         RowBox[{"-", 
          FractionBox[
           RowBox[{"Cos", "[", "\[Theta]", "]"}], 
           SqrtBox["101"]]}], ",", 
         FractionBox["10", 
          SqrtBox["101"]]}], "}"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", "0", ",", 
       RowBox[{"10", "\[Pi]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Phi]", ",", "0", ",", 
       RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
     RowBox[{"PlotPoints", "->", 
      RowBox[{"{", 
       RowBox[{"50", ",", " ", "20"}], "}"}]}]}], "\[IndentingNewLine]", 
    "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r", ",", "0.1"}], "}"}], ",", "0", ",", "1"}], "}"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
