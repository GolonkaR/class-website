Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r", "=", "0.5"}], ",", " ", "F", ",", " ", "vel", ",", "accel", 
     ",", "directionV", ",", "normalVector", ",", " ", "binormalV"}], "}"}], ",",
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"F", "[", "\[Theta]_", "]"}], ":=", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"2", "\[Theta]"}], "]"}], ",", 
        RowBox[{"Sin", "[", 
         RowBox[{"2", "\[Theta]"}], "]"}], ",", "0"}], "}"}], "+", 
      RowBox[{"r", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"3", "\[Theta]"}], "]"}], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"2", "\[Theta]"}], "]"}], ",", 
         RowBox[{"Sin", "[", 
          RowBox[{"2", "\[Theta]"}], "]"}], ",", "0"}], "}"}]}], "+", 
      RowBox[{"r", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"3", "\[Theta]"}], "]"}], 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "1"}], "}"}]}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"vel", "=", 
     RowBox[{"Function", "[", 
      RowBox[{"t", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"F", "[", "\[Theta]", "]"}], ",", "\[Theta]"}], "]"}], 
         ")"}], "/.", 
        RowBox[{"\[Theta]", "->", "t"}]}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"accel", " ", "=", " ", 
     RowBox[{"Function", "[", 
      RowBox[{"t", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"F", "[", "\[Theta]", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"\[Theta]", ",", "2"}], "}"}]}], "]"}], ")"}], "/.", 
        RowBox[{"\[Theta]", "->", "t"}]}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"directionV", "=", 
     RowBox[{"Function", "[", 
      RowBox[{"t", ",", 
       RowBox[{"Normalize", "[", 
        RowBox[{"vel", "[", "t", "]"}], "]"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"normalVector", "=", 
     RowBox[{"Function", "[", 
      RowBox[{"t", ",", 
       RowBox[{"Normalize", "[", 
        RowBox[{
         RowBox[{"accel", "[", "t", "]"}], "-", 
         RowBox[{"Projection", "[", 
          RowBox[{
           RowBox[{"accel", "[", "t", "]"}], ",", 
           RowBox[{"vel", "[", "t", "]"}]}], "]"}]}], "]"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"binormalV", "=", 
     RowBox[{"Function", "[", 
      RowBox[{"t", ",", 
       RowBox[{"Cross", "[", 
        RowBox[{
         RowBox[{"directionV", "[", "t", "]"}], ",", 
         RowBox[{"normalVector", "[", "t", "]"}]}], "]"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"F", "[", "t", "]"}], "+", 
       RowBox[{"r", " ", 
        RowBox[{"Cos", "[", "\[Phi]", "]"}], 
        RowBox[{"normalVector", "[", "t", "]"}]}], "+", 
       RowBox[{"r", " ", 
        RowBox[{"Sin", "[", "\[Phi]", "]"}], 
        RowBox[{"binormalV", "[", "t", "]"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", 
        RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Phi]", ",", "0", ",", 
        RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
